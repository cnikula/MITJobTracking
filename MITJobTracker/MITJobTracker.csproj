    <PackageReference Include="Syncfusion.Blazor.Grid" Version="26.1.41" />
    <PackageReference Include="Syncfusion.Blazor.Inputs" Version="26.1.41" />
    <PackageReference Include="Syncfusion.Blazor.Popups" Version="26.1.41" />
    <PackageReference Include="Syncfusion.Blazor.SplitButtons" Version="26.1.41" />
